# --- CSP (src/proxy.ts, src/lib/content-security-policy.ts) ---
# "true" adds require-trusted-types-for + trusted-types in production only.
# May break third-party scripts (GTM, Clarity, etc.); test before enabling on prod.
ENABLE_TRUSTED_TYPES=false

# "true" or "1" disables the Content-Security-Policy header (local debugging only).
DISABLE_CSP=1

NEXT_TELEMETRY_DISABLED=1



# --- reCAPTCHA & forms (src/app/api/*-form/, src/lib/recaptcha-*.ts) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Optional minimum score (0–1). Defaults apply if unset.
# RECAPTCHA_MIN_SCORE=

TELEGRAM_BOT_TOKEN=

# --- Optional: bundle analyzer (next.config.ts) ---
# ANALYZE=true
