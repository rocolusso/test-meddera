# =============================================================================
# Скопируйте в .env.local и заполните. В Vercel: Settings → Environment Variables.
# Секреты не коммитьте.
#
# --- Vercel Production: без этих трёх формы вернут 503 на /api/form-token ---
# 1) Подключите Upstash Redis (Marketplace) → UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
# 2) Добавьте FORM_TOKEN_SECRET (≥ 16 символов), например: openssl rand -base64 48
# 3) Пересоберите деплой после сохранения переменных
# Аварийно: DISABLE_FORM_ABUSE_PROTECTION=1 отключает защиту (только reCAPTCHA).
# =============================================================================

NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# reCAPTCHA v3 + Telegram (формы контактов)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# RECAPTCHA_MIN_SCORE=0.5

TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Защита форм: rate limit + anti-replay + HMAC-токен
# Код: src/proxy.ts, src/lib/contact-form-processor.ts, src/lib/form-token.ts
# -----------------------------------------------------------------------------

# --- Upstash Redis (обязательно для продакшена с защитой форм) ---
# После установки интеграции в Vercel Marketplace переменные часто подставляются сами.
# Имена должны совпадать с этими (используются в коде как есть):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Секрет для подписи токена GET /api/form-token (HMAC). Минимум ~16 символов;
# в проде — длинная случайная строка (например: openssl rand -base64 48).
FORM_TOKEN_SECRET=

# Аварийный откат: только старая логика (reCAPTCHA → Telegram), без токена/скоринга/Redis replay.
# DISABLE_FORM_ABUSE_PROTECTION=1

# -----------------------------------------------------------------------------
# Опционально (локальная отладка / старые флаги)
# -----------------------------------------------------------------------------
# ENABLE_TRUSTED_TYPES=false
# DISABLE_CSP=1

# ANALYZE=true
